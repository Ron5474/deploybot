# ── LLM (main model) ──────────────────────────────────────────────────────────
# Base URL of an OpenAI-compatible API (e.g. Ollama, vLLM, OpenRouter, etc.)
MODEL_BASE_URL=http://localhost:11434/v1
MODEL_API_KEY=your-api-key-here
MODEL_NAME=your-model-name-here

# ── LLM (small/fast model — used for benchmarks) ──────────────────────────────
SMALL_MODEL_API_KEY=your-small-model-api-key-here
SMALL_MODEL_NAME=your-small-model-name-here

# ── Tavily web search ──────────────────────────────────────────────────────────
# Get a free key at https://tavily.com
TAVILY_TOKEN=tvly-...

# ── GitHub token (data scraper only) ──────────────────────────────────────────
# Used to fetch app READMEs from GitHub. Needs read:public_repo scope.
# Only required when running data/scraper.py to rebuild the app catalog.
GITHUB_ACCESS_TOKEN=ghp_...

# ── Optional ──────────────────────────────────────────────────────────────────
# Set to any value to disable the LangChain SQLite response cache
# DISABLE_CACHE=1
